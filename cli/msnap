  # :dependency.filter
  if ! command -v grim >/dev/null 2>&1; then
    printf "missing dependency: grim\n" >&2
    missing_deps=1
  else
    deps['grim']="$(command -v grim | head -n1)"
  fi

  # :dependency.filter
  if ! command -v slurp >/dev/null 2>&1; then
    printf "missing dependency: slurp\n" >&2
    missing_deps=1
  else
    deps['slurp']="$(command -v slurp | head -n1)"
  fi

  # :dependency.filter
  if ! command -v wl-copy >/dev/null 2>&1; then
    printf "missing dependency: wl-copy\n" >&2
    missing_deps=1
  else
    deps['wl-copy']="$(command -v wl-copy | head -n1)"
