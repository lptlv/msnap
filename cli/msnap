# :command.initialize
initialize() {
  declare -g version="0.2.3"
  set -e

  # src/initialize.sh
  XDG_CONFIG_DIRS="${XDG_CONFIG_DIRS:-/etc/xdg}"
  config_home="${XDG_CONFIG_HOME:-${HOME}/.config}"

  IFS=':' read -ra _dirs <<< "$config_home:$XDG_CONFIG_DIRS"
  for dir in "${_dirs[@]}"; do
    if [[ -f "$dir/msnap/msnap.conf" ]]; then
      ini_load "$dir/msnap/msnap.conf"
      break
    fi
  done
}

# :command.run
run() {
  # :command.globals
  declare -g long_usage=''
  declare -g -A args=()
  declare -g -A deps=()
  declare -g -a env_var_names=()
  declare -g -a input=()

  normalize_input "$@"
  parse_requirements "${input[@]}"

  case "$action" in
    "shot") msnap_shot_command ;;
    "cast") msnap_cast_command ;;
    "gui") msnap_gui_command ;;
    "uninstall") msnap_uninstall_command ;;
    "update") msnap_update_command ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  # :command.start
  command_line_args=("$@")
  initialize
  run "${command_line_args[@]}"
fi
